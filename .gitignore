## .NET Core 8 Web App – .gitignore

# Build outputs
bin/
obj/

# Visual Studio / Rider
.vs/
*.user
*.suo
*.userprefs
*.pidb
*.ncb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# JetBrains Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Publish output
**/publish/
**/PublishProfiles/

# Entity Framework migrations (optional – remove if you want to commit them)
# **/Migrations/

# App settings with secrets (keep appsettings.json, ignore environment-specific overrides)
appsettings.*.json
!appsettings.Development.json

# .NET user secrets
secrets.json

# Logs
*.log
logs/

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Compiled assets / node_modules (if using npm/Webpack alongside ASP.NET)
node_modules/
wwwroot/dist/
wwwroot/lib/

# Test results
TestResults/
coverage/
*.coverage
*.coveragexml

# Certificates / key files
*.pfx
*.p12
*.key
*.pem
